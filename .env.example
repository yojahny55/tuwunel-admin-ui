# Tuwunel server URL (internal or external)
MATRIX_SERVER_URL=http://your-server:6167

# Your Matrix server domain
MATRIX_DOMAIN=example.local

# Registration token (must match TUWUNEL_REGISTRATION_TOKEN on your server)
MATRIX_REGISTRATION_TOKEN=your-registration-token

# Admin room ID (send !admin in a DM to find it, or leave empty to skip admin ops)
MATRIX_ADMIN_ROOM_ID=

# Admin credentials
ADMIN_USERNAME=your-admin-username
ADMIN_PASSWORD=your-admin-password

# JWT secret (generate with: openssl rand -hex 32)
JWT_SECRET=change-me-to-a-random-string

# Server port
PORT=3002
